{
    "manifest_version": 3,
    "name": "YT Download Assist",
    "version": "2.0",
    "description": "Educational tool for downloading YouTube videos using yt-dlp natively.",
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "downloads",
        "storage"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "YT Download Assist"
    },
    "host_permissions": [
        "*://*.youtube.com/*",
        "*://*/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.youtube.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ]
        }
    ]
}